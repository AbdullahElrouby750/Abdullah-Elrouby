<link rel="stylesheet" href="{{ 'shop-the-look.css' | asset_url }}">
<script src="{{ 'shop-the-look.js' | asset_url }}" defer="defer"></script>

<shop-the-look class="shop-the-look" data-section-id="{{ section.id }}" data-bonus-variant-id="{{ section.settings.bonus_product.variants.first.id }}">
  <div class="modal-overlay"></div>

  <div class="grid-header">
    <h2 class="grid-title">{{ section.settings.heading }}</h2>
    <a href="{{ section.settings.view_all_link }}" class="view-all-link">View all</a>
  </div>

  <div class="looks-grid">
    {% for block in section.blocks %}
      {% if block.type == 'look' %}
        <div class="look-card" data-block-id="{{ block.id }}">
          <img
            src="{{ block.settings.image | img_url: '600x600' }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="look-main-img"
          >

          <button
            type="button"
            class="hotspot-btn"
            style="top: {{ block.settings.hotspot_y }}%; left: {{ block.settings.hotspot_x }}%;"
            aria-label="View product"
          >
            {% render 'icon-hotspot-check' %}
          </button>

          {% if block.settings.product != blank %}
            {% assign product = block.settings.product %}
            <div class="product-modal">
              <button type="button" class="modal-close" aria-label="Close Modal">✕</button>

              <div class="modal-header-flex">
                <img
                  src="{{ product.featured_image | img_url: '300x300' }}"
                  alt="{{ product.title | escape }}"
                  class="product-thumbnail"
                >
                <div class="product-info">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <p class="product-price">{{ product.price | money }}</p>
                  <div class="product-desc">{{ product.description | strip_html | truncatewords: 15 }}</div>
                </div>
              </div>

              <div class="product-options">
                {% for option in product.options_with_values %}
                  {% if option.name == 'Color' %}
                    <div class="option-group">
                      <span class="option-label">Color</span>
                      <div class="color-picker-ui" style="--option-count: {{ option.values.size }};">
                        {% for value in option.values %}
                          <!-- Passes the color handle to CSS for the left stripe -->
                          <label class="color-swatch" style="--swatch-color: {{ value | downcase | handle }};">
                            <input
                              type="radio"
                              name="color-{{ block.id }}"
                              value="{{ value | escape }}"
                              {% if forloop.first %}
                                checked
                              {% endif %}
                              hidden
                            >
                            <span class="swatch-text">{{ value }}</span>
                          </label>
                        {% endfor %}
                      </div>
                    </div>

                  {% elsif option.name == 'Size' %}
                    <div class="option-group">
                      <span class="option-label">Size</span>
                      <div class="custom-select-wrapper">
                        <button type="button" class="custom-select-trigger">
                          <span class="selected-value">Choose your size</span>
                          <span class="chevron">
                            <svg
                              width="12"
                              height="8"
                              viewBox="0 0 12 8"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M1 1.5L6 6.5L11 1.5" stroke="black" stroke-width="1.5"/>
                            </svg>
                          </span>
                        </button>
                        <ul class="custom-select-options">
                          {% for value in option.values %}
                            <li class="custom-select-option" data-value="{{ value | escape }}">{{ value }}</li>
                          {% endfor %}
                        </ul>
                        <!-- Hidden input to store JS state -->
                        <input type="hidden" name="size-{{ block.id }}" value="">
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>

              <button type="button" class="add-to-cart-button">
                <span class="btn-text">ADD TO CART</span>
                <span class="btn-icon">{% render 'icon-arrow' %}</span>
              </button>

              <script type="application/json" class="product-variants-data">
                {{ product.variants | json }}
              </script>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</shop-the-look>

{% schema %}
{
  "name": "Shop the look grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link",
      "default": "/collections/all"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Bonus Product (Soft Winter Jacket)"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Lifestyle Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured Product"
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "label": "Hotspot X Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "label": "Hotspot Y Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the look grid"
    }
  ]
}
{% endschema %}
